# Copy this file to `.env` and adjust the paths for your machine.

# File operation mode:
# - NO_CHANGE
# - MOVE
# - COPY
MODE=MOVE

# Input folder that contains new PDFs.
FOLDER_INBOX="C:/Path/To/Scan"

# Optional. If omitted, these default to subfolders under FOLDER_INBOX.
# FOLDER_REVIEW="C:/Path/To/Scan/Review"
# FOLDER_UNSURE="C:/Path/To/Scan/Unsure"

# Final destination root for reviewed documents.
DEST_ROOT="C:/Path/To/Documents"

# Optional separate training root. If omitted, DEST_ROOT is used.
# TRAIN_DATA_PATH="C:/Path/To/TrainingData"

# Local GGUF model path used by llama-cpp-python.
LLM_MODEL_PATH="C:/Path/To/Models/model.gguf"

# Optional tuning values.
# UNSURE_THRESHOLD=0.75
# ERROR_PAUSE_SECONDS=7200
